# Cloud deployment environment variables
# Copy to .env.cloud and fill in values, then:
#   docker compose -f docker-compose.yml -f docker-compose.cloud.yml --env-file .env.cloud up -d

# ── Groq API (free LLM — https://console.groq.com) ──────────────────────────
# Create account → API Keys → Create API Key
GROQ_API_KEY=gsk_REPLACE_ME

# ── Qdrant Cloud (free vector DB — https://cloud.qdrant.io) ─────────────────
# Create free cluster → Dashboard → API Keys
# QDRANT_CLOUD_HOST format: <cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_CLOUD_HOST=xyz.eu-central.aws.cloud.qdrant.io
QDRANT_CLOUD_API_KEY=REPLACE_ME

# ── Frontend (URL of the deployed backend) ───────────────────────────────────
# On Render: https://researchmind-backend.onrender.com
# Locally with cloud services: http://localhost:8001
BACKEND_URL=http://localhost:8001

# ── Langfuse (optional observability — https://cloud.langfuse.com) ───────────
# Leave empty to disable tracing
LANGFUSE_DB_PASSWORD=changeme_strong_password
LANGFUSE_NEXTAUTH_SECRET=changeme_random_32chars
LANGFUSE_SALT=changeme_random_salt
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
