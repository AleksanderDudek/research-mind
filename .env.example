# LiteLLM
LITELLM_MASTER_KEY=sk-researchmind-local

# Backend
QDRANT_HOST=qdrant
QDRANT_PORT=6333
LITELLM_BASE_URL=http://litellm:4000
LITELLM_API_KEY=sk-researchmind-local
LLM_MODEL=local-llm

# Opcjonalnie: zewnętrzne LLM
# OPENAI_API_KEY=sk-...
# HF_TOKEN=hf_...

# Langfuse (observability) — wymagane przez docker-compose langfuse-db + langfuse
LANGFUSE_DB_PASSWORD=changeme_strong_password
LANGFUSE_NEXTAUTH_SECRET=changeme_random_32chars
LANGFUSE_SALT=changeme_random_salt

# Langfuse API keys — pobierz z http://localhost:3000 po pierwszym logowaniu
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
